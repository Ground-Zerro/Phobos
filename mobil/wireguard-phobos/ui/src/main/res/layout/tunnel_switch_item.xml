<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingTop="4dp"
    android:paddingEnd="4dp"
    android:paddingBottom="4dp">

    <CheckBox
        android:id="@+id/cb_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tv_tunnel_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_move_up"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/tunnel_switch_move_up"
        android:text="▲"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_move_down"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/tunnel_switch_move_down"
        android:text="▼"
        android:textSize="16sp" />
</LinearLayout>
